#Modelling interactions - see note about multicollinearity clash! Adapt code to remove items if column data overlap
#Plain Eng: lm(outcome variable ∼ predictor variable*another predictor variable/effect + another combo, data = dataset)
vowel.logf1.lm = lm(F1_log ~ Sex*Text.type + Sex*Word, data = vowel.data.log)
summary(vowel.logf1.lm)

#etc. for different conditions and F2 and F3
vowel.logf2.lm = lm(F2n_log ~ Sex*F1_log + Sex*F3_log + Human.or.clone*F1_log + Human.or.clone*F3_log, data = vowel.data.log)
summary(vowel.logf2.lm)

#Boxplots of modelled interactions (log base 10 normalised)
vowel.data.log %>%
