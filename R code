vowels <- read.csv("Vowels.csv")

#Calculating the midpoint timepoint if not already extracted
vowels$Mid <- (vowels$Start + vowels$End)/2

#Shapiro test for normal distribution of data
shapiro.test(vowels$F2norm) # Change dataframe and object to whatever's needed

#Distribution histograms - to test if normal distribution for further tests. Change dataframe and object as needed
ggplot(vowels, aes(x = F2norm, fill = Sex)) + geom_density(alpha = .5)
ggplot(vowels, aes(x = F2norm, fill = Human.or.clone)) + geom_density(alpha = .5)
ggplot(vowels, aes(x = F2norm, fill = Text.type)) + geom_density(alpha = .5)

#Non-normalised means of vowels
vowels.nonnorm.means = vowels %>%
  group_by(SpeakerID, Human.or.clone, Sex) %>%
  summarise(
    F1 = mean(F1_50),
    F2 = mean(F2_50),
    F3 = mean(F3_50)
  )

#Normalisation and calculating normalised means - intrinsic method - log base 10

#Log normalisation - all data
#Mutate() to create new columns with the log10 values
vowel.data.log <- vowels %>%
  mutate(
    F1_log = log10(F1_50),
    F2_log = log10(F2_50),
    F3_log = log10(F3_50)
  )

#Average out the output values to calculate normalised means
#Group by speaker and vowel to get the mean log formants
vowel.log.means <- vowel.data.log %>%
  group_by(SpeakerID, Human.or.clone, Sex, Word, Lexical.set) %>%
  summarise(
    mean_F1_log = mean(F1_log),
    mean_F2_log = mean(F2_log),
    mean_F3_log = mean(F3_log),
    .groups = 'drop' # Drops the grouping structure afterwards
  )

#Create vowel space graph
#Plotting F2 on the x-axis and F1 on the y-axis
vowel.log.means %>%
  ggplot()+
  aes(x = mean_F2_log, y = mean_F1_log, colour = Human.or.clone, fill = Human.or.clone, label = SpeakerID) +
  geom_point(size = 1) +
  geom_text(size = 3, vjust = -1) +
  scale_x_reverse() +
  scale_y_reverse() +
  labs(
    x = "Mean F2 (log base 10)",
    y = "Mean F1 (log base 10)",
    title = "Log-normalised means of Belfast FOOT /u/, all speakers, all conditions"
    ) +
  theme_minimal()

