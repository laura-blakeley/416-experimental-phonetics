#Creating pairs and plots LOG BASE 10 NORMALISED to show overlaid ellipses of each speaker pair
paired.norm4 <- vowel.data.log %>%
  mutate(
    base_id   = str_extract(SpeakerID, "^\\d+"),
    condition = str_extract(SpeakerID, "[HC](?=[OB]$)"),  # H or C (second last)
    set       = str_extract(SpeakerID, "[OB]$"),          # O or B (last)
    pair_id   = paste(base_id, set, sep = "_")
  )
paired.norm4 %>%
  ggplot() +
  aes(x = F2_log, y = F1_log, colour = SpeakerID) +
  geom_point(alpha = 0.4) +
  stat_ellipse(level = 0.95, linewidth = 1) + 
  scale_y_reverse() +
  scale_x_reverse() +
  facet_wrap(~ pair_id) +
  theme_minimal() +
  labs(
    title = "F1 and F2 values, log-normalised, by speaker pair and condition",
    x = "F2 (log base 10 normalised)",
    y = "F1 (log base 10 normalised)",
    colour = "Speaker ID"
  )
#Plus with words labelled
paired.norm4 %>%
  ggplot() +
  aes(x = F2_log, y = F1_log, colour = SpeakerID, label = Word) +
  geom_text(size = 0.5) +
  stat_ellipse(level = 0.95, linewidth = 1) + 
  scale_y_reverse() +
  scale_x_reverse() +
  facet_wrap(~ pair_id) +
  theme_minimal() +
  labs(
    title = "F1 and F2 values with words, log-normalised, by speaker pair and condition",
    x = "F2 (log base 10 normalised)",
    y = "F1 (log base 10 normalised)",
    colour = "Speaker ID"
  )

